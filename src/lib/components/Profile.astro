---
import { Image } from "astro:assets";
import Avatar from "$src/assets/pfp.jpg";
import { cn } from "$lib/utils.ts";
import ThemeSwitcher from "src/lib/components/ThemeSwitcher.svelte";
import { Button } from "./ui/button";

interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props as Props;
---

<section class={cn("flex flex-col gap-y-4", className)}>
  <Image
    src={Avatar}
    alt="Profile picture"
    class="border-muted large:size-48 size-36 rounded-full border-2"
  />

  <a
    class={cn(
      Astro.url.pathname === "/" ? "hover:cursor-default" : "hover:cursor-pointer",
      "hover:no-underline"
    )}
    href="/"
    ><h1 class="text-3xl font-extrabold">
      Paillat <span class="text-muted-foreground font-light italic">· Any</span>
    </h1>
  </a>
  <hr />
  <p class="text-muted-foreground text-base leading-loose">
    FR • IT • EN • DE
    <br />
    I enjoy building things on the internet 😄
    <br />
    Chicago Manual of Style 17th edition (full note)
  </p>
  <div class="flex flex-row gap-2">
    {
      !Astro.url.pathname.startsWith("/post") && (
        <Button variant="link" href="/post">
          Blog
        </Button>
      )
    }
    <ThemeSwitcher client:load />
  </div>
</section>

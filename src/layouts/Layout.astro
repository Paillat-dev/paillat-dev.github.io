---
import Seo from "$lib/components/Seo.astro";
import "$src/styles/global.css";
import BuyMeACoffee from "$lib/components/BuyMeACoffee.astro";
import { ClientRouter } from "astro:transitions";
import "@fontsource-variable/tasa-orbiter";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image }: Props = Astro.props;
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <BuyMeACoffee />

    <Seo title={title} description={description} image={image} />

    <ClientRouter />
    <script is:inline>
      function applyTheme() {
        const stored = localStorage.getItem("theme");
        document.documentElement.classList.remove("dark", "light");
        if (stored) document.documentElement.classList.add(stored);
      }

      applyTheme();
      document.removeEventListener("astro:after-swap", applyTheme);
      document.addEventListener("astro:after-swap", applyTheme);
    </script>
    <slot name="head" />
  </head>
  <body class="bg-background text-foreground antialiased">
    <a href="#main-content" class="skip-to-content"> Skip to main content </a>
    <slot />
    <footer class="bg-muted large:p-10 p-4">
      <p class="text-muted-foreground text-center text-sm">
        &#169; Paillat-dev 2026{year === 2026 ? "" : `-${year}`} All rights reserved.
      </p>
    </footer>
  </body>
</html>

<style>
  .skip-to-content {
    position: absolute;
    top: -40px;
    left: 0;
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    padding: 8px 16px;
    text-decoration: none;
    z-index: 100;
    font-weight: 600;
    border-radius: 0 0 4px 0;
  }

  .skip-to-content:focus {
    top: 0;
  }
</style>

---
import { getCollection } from "astro:content";
import Layout from "$src/layouts/Layout.astro";
import LeftProfileLayout from "$lib/components/LeftProfileLayout.astro";
import BentoCards from "$lib/components/cards/BentoCards.astro";
import SimpleBreadcrumb from "$lib/components/SimpleBreadcrumb.svelte";
import PostCard from "$lib/components/cards/PostCard.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog" description="My blog posts">
  <LeftProfileLayout class="min-h-screen">
    <SimpleBreadcrumb
      pages={[
        { label: "Home", href: "/" },
        { label: "Blog", href: "/post", disabled: true },
      ]}
      class="px-8"
    />
    <BentoCards>
      {posts.map((post) => <PostCard post={post} />)}
    </BentoCards>
  </LeftProfileLayout>
</Layout>
